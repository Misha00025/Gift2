--- !u!114 &166379011
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 166379009}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b89b2c8d34df52d4e89cba040401d38b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::HeneGames.DialogueSystem.DialogueManager
  audioSource: {fileID: 0}
  startDialogueEvent:
    m_PersistentCalls:
      m_Calls: []
  nextSentenceDialogueEvent:
    m_PersistentCalls:
      m_Calls: []
  endDialogueEvent:
    m_PersistentCalls:
      m_Calls: []
  triggerState: 0
  sentences:
  - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
    sentence: "\u041F\u0440\u0438\u0432\u0435\u0442! \u0421\u043F\u0430\u0441\u0438\u0431\u043E,
      \u0447\u0442\u043E \u043F\u0440\u0438\u0448\u043B\u0430! \u0422\u044B \u043A\u0430\u043A
      \u0440\u0430\u0437 \u0432\u043E\u0432\u0440\u0435\u043C\u044F!"
    skipDelayTime: 0
    sentenceSound: {fileID: 0}
    sentenceEvent:
      m_PersistentCalls:
        m_Calls: []
  - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
    sentence: "\u041C\u044B \u043A\u0430\u043A \u0440\u0430\u0437 \u0445\u043E\u0442\u0435\u043B\u0438
      \u043E\u0442\u043A\u0440\u044B\u0442\u044C \u043D\u0430\u0448\u0443 \"\u041C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0443\u044E
      \u0434\u0440\u0443\u0437\u0435\u0439\", \u043D\u043E \u0442\u0443\u0442 \u043F\u043E\u043D\u044F\u043B\u0438,
      \u0447\u0442\u043E \u0443 \u043D\u0430\u0441 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432, \u0447\u0442\u043E\u0431\u044B
      \u0445\u043E\u0442\u044C \u0447\u0442\u043E-\u0442\u043E \u043D\u0430\u0447\u0430\u0442\u044C
      \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u0442\u044C. "
    skipDelayTime: 0
    sentenceSound: {fileID: 0}
    sentenceEvent:
      m_PersistentCalls:
        m_Calls: []
  - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
    sentence: "\u0422\u044B \u0436\u0435 \u043F\u043E\u043C\u043E\u0436\u0435\u0448\u044C
      \u043D\u0430\u043C \u0434\u043E\u0431\u044B\u0442\u044C \u0432\u0441\u0451
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0435?"
    skipDelayTime: 0
    sentenceSound: {fileID: 0}
    sentenceEvent:
      m_PersistentCalls:
        m_Calls: []
  - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
    sentence: "\u042F \u043F\u043E\u043A\u0430 \u0437\u0430\u0439\u043C\u0443\u0441\u044C
      \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0434\u0435\u043B\u0430\u043C\u0438,
      \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043C\u043E\u0436\u0435\u0448\u044C
      \u043F\u043E\u0434\u043E\u0439\u0442\u0438 \u043A\u043E \u043C\u043D\u0435
      \u043F\u043E\u043F\u043E\u0437\u0436\u0435?"
    skipDelayTime: 0
    sentenceSound: {fileID: 0}
    sentenceEvent:
      m_PersistentCalls:
        m_Calls: []
  - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
    sentence: "\u0410 \u043F\u043E\u043A\u0430 \u043C\u043E\u0436\u0435\u0448\u044C
      \u043F\u043E\u043C\u043E\u0447\u044C \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u043C
      \u0432 \u0438\u0445 \u043F\u0440\u043E\u0441\u044C\u0431\u0430\u0445."
    skipDelayTime: 0
    sentenceSound: {fileID: 0}
    sentenceEvent:
      m_PersistentCalls:
        m_Calls: []
