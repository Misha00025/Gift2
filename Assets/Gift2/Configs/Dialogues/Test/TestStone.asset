  m_Script: {fileID: 11500000, guid: 9cf7ce9063895de71a9d3ea38266693c, type: 3}
  m_Name: TestStone
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::Wof.DialogueSystem.SentencesConfig
  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0410 \u0434\u043E\u0431\u0443\u0434\u044C \u0434\u043B\u044F \u043C\u0435\u043D\u044F
        \u0435\u0449\u0451 \u0438 \u043A\u0430\u043C\u0435\u043D\u044C!"
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u042F \u0432\u0441\u0451 \u0435\u0449\u0451 \u0436\u0434\u0443
        \u043A\u0430\u043C\u043D\u0438."
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E! \u0422\u0435\u043F\u0435\u0440\u044C
        \u044F \u0441\u043C\u043E\u0433 \u043E\u0442\u043A\u0440\u044B\u0442\u044C
        \u043C\u0430\u0433\u0430\u0437\u0438\u043D \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0439! "
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u0430\u043C \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
        \u0443\u043F\u0440\u043E\u0441\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u0435
        \u0434\u043E\u0431\u044B\u0447\u0443 \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432. "
  NoQuests:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u042F \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043E\u0442 \u0442\u0435\u0431\u044F
        \u0432\u0441\u0451, \u0447\u0442\u043E \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
        \u0431\u044B\u043B\u043E. "
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041C\u043E\u0436\u0435\u0448\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
        \u0441\u0432\u043E\u0438\u043C\u0438 \u0434\u0435\u043B\u0430\u043C\u0438."
