  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041F\u0440\u0438\u0432\u0435\u0442! \u041F\u043E\u043C\u043E\u0433\u0438
        \u043C\u043D\u0435 \u0434\u043E\u0431\u044B\u0442\u044C \u043A\u0430\u043C\u043D\u0435\u0439,
        \u0434\u0435\u0440\u0435\u0432\u0430 \u0438 \u0432\u043E\u0441\u043A\u0430."
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u044B \u0443\u0436\u0435 \u0434\u043E\u0431\u044B\u043B \u0442\u043E
        \u0447\u0442\u043E \u044F \u043F\u0440\u043E\u0441\u0438\u043B?"
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041D\u0435\u0442? \u041B\u0430\u0434\u043D\u043E. \u0416\u0434\u0443..."
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E! \u0422\u044B \u043E\u0447\u0435\u043D\u044C
        \u043C\u0435\u043D\u044F \u0432\u044B\u0440\u0443\u0447\u0438\u043B!"
  NoQuests:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u044B \u043C\u043E\u043B\u043E\u0434\u0435\u0446! \u0422\u044B
        \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u0411\u0435\u0442\u0430-\u0442\u0435\u0441\u0442!"
