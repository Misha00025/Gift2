  m_Script: {fileID: 11500000, guid: 9cf7ce9063895de71a9d3ea38266693c, type: 3}
  m_Name: TestDialogue
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::Wof.DialogueSystem.SentencesConfig
  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041F\u043E\u043C\u043E\u0433\u0438 \u043C\u043D\u0435 \u0435\u0449\u0451
        \u0434\u043E\u0431\u044B\u0442\u044C \u043A\u0430\u043C\u043D\u0435\u0439,
        \u0434\u0435\u0440\u0435\u0432\u0430 \u0438 \u0432\u043E\u0441\u043A\u0430."
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0412\u043E\u0441\u043A \u0442\u044B \u043D\u0430\u0439\u0434\u0451\u0448\u044C
        \u043D\u0430 \u0432\u043E\u0441\u0442\u043E\u043A\u0435. \u041E\u043D \u0432\u044B\u043F\u0430\u0434\u0430\u0435\u0442
        \u0438\u0437 \u0443\u043B\u044C\u0435\u0432. "
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0427\u0442\u043E\u0431\u044B \u0435\u0433\u043E \u0434\u043E\u0431\u044B\u0442\u044C
        \u043F\u0440\u043E\u043A\u0430\u0447\u0430\u0439 \u0434\u0432\u0430\u0436\u0434\u044B
        \u0441\u0438\u043B\u0443 \u0443 \u043C\u0435\u043D\u044F \u0432 \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0435.
        \u0418\u043D\u0430\u0447\u0435 \u0442\u0432\u043E\u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
        \u043D\u0435 \u0431\u0443\u0434\u0443\u0442 \u043D\u0430\u043D\u043E\u0441\u0438\u0442\u044C
        \u0443\u0440\u043E\u043D \u0443\u043B\u044C\u044F\u043C."
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u044B \u043F\u043E\u043C\u043D\u0438\u0448\u044C, \u0447\u0442\u043E
        \u0432\u043E\u0441\u043A \u043C\u043E\u0436\u043D\u043E \u0434\u043E\u0431\u044B\u0442\u044C
        \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u043E\u043A\u0430\u0447\u0430\u0432
        \u0441\u0438\u043B\u0443?"
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E! \u0422\u044B \u043E\u0447\u0435\u043D\u044C
        \u043C\u0435\u043D\u044F \u0432\u044B\u0440\u0443\u0447\u0438\u043B!"
  NoQuests:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u044B \u043C\u043E\u043B\u043E\u0434\u0435\u0446! \u0422\u044B
        \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u0411\u0435\u0442\u0430-\u0442\u0435\u0441\u0442!"
