  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0414\u043E\u0431\u0443\u0434\u044C \u0434\u043B\u044F \u043C\u0435\u043D\u044F
        \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0434\u0435\u0440\u0435\u0432\u0430."
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u043E\u043F\u043E\u0440 \u043C\u043E\u0436\u0435\u0448\u044C
        \u0432\u0437\u044F\u0442\u044C \u0432 \u0434\u043E\u043C\u0435."
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u0422\u044B \u043F\u043E\u043C\u043D\u0438\u0448\u044C, \u0447\u0442\u043E
        \u0442\u043E\u043F\u043E\u0440 \u0432 \u0434\u043E\u043C\u0435?"
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E. \u0414\u0435\u0440\u0436\u0438
        \u041A\u0438\u0440\u043A\u0443!"
  NoQuests:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u042F \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043E\u0442 \u0442\u0435\u0431\u044F
        \u0432\u0441\u0451, \u0447\u0442\u043E \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
        \u0431\u044B\u043B\u043E. "
    - dialogueCharacter: {fileID: 11400000, guid: 475ede97f02c53ce3884bab48de42577, type: 2}
      sentence: "\u041C\u043E\u0436\u0435\u0448\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
        \u0441\u0432\u043E\u0438\u043C\u0438 \u0434\u0435\u043B\u0430\u043C\u0438."
