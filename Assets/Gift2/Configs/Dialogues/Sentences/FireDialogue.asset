  m_Script: {fileID: 11500000, guid: 9cf7ce9063895de71a9d3ea38266693c, type: 3}
  m_Name: FireDialogue
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::Wof.DialogueSystem.SentencesConfig
  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E \u0442\u044B
        \u0434\u043E\u0431\u0440\u0430\u043B\u0430\u0441\u044C \u0438 \u0434\u043E
        \u043C\u0435\u043D\u044F!"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u042F \u0443\u0436 \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E
        \u0442\u044B \u0440\u0435\u0448\u0438\u043B\u0430 \u0434\u043E\u0431\u044B\u0432\u0430\u0442\u044C
        \u0442\u0443\u0442 \u0440\u0435\u0441\u0443\u0440\u0441\u044B \u0432\u0435\u0447\u043D\u043E\u0441\u0442\u044C~"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u0412\u043E\u043E\u0431\u0449\u0435, \u0443 \u043C\u0435\u043D\u044F
        \u0442\u043E\u0436\u0435 \u0435\u0441\u0442\u044C \u043F\u0440\u043E\u0441\u044C\u0431\u0430
        \u043A \u0442\u0435\u0431\u0435."
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u041D\u0435 \u043C\u043E\u0433\u043B\u0430 \u0431\u044B \u0442\u044B
        \u0434\u043E\u0431\u044B\u0442\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E
        \u0432\u043E\u0441\u043A\u0430?"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u0417\u0430\u0447\u0435\u043C \u043C\u043D\u0435 \u0432\u043E\u0441\u043A?"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u042D\u0442\u043E \u0441\u0435\u043A\u0440\u0435\u0442~"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u0414\u0443\u043C\u0430\u044E, \u0442\u044B \u0443\u0436\u0435
        \u0432\u0438\u0434\u0435\u043B\u0430 \u043F\u0430\u0441\u0435\u043A\u0443,
        \u043A\u043E\u0433\u0434\u0430 \u0445\u043E\u0434\u0438\u043B\u0430 \u043A
        \u043A\u0430\u0440\u044C\u0435\u0440\u0443."
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: ...
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: ...
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: ...
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u041C..? \u0423 \u043C\u0435\u043D\u044F \u0447\u0442\u043E-\u0442\u043E
        \u043D\u0430 \u043B\u0438\u0446\u0435?"
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u0423\u0440\u0430! \u0423\u0440\u0430! \u0423\u0440\u0430!"
    - dialogueCharacter: {fileID: 11400000, guid: 5b0962cba0bb0f138b7263e1dc4660a2, type: 2}
      sentence: "\u0422\u0435\u043F\u0435\u0440\u044C \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432
        \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E! \u041C\u044B
        \u043C\u043E\u0436\u0435\u043C \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F!"
  NoQuests:
    Sentences: []
