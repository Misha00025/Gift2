--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9cf7ce9063895de71a9d3ea38266693c, type: 3}
  m_Name: WindDialogue
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::Wof.DialogueSystem.SentencesConfig
  AcceptQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041F\u0440\u0438\u0432\u0435\u0442!"
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041F\u043E\u043C\u043E\u0436\u0435\u0448\u044C \u043C\u043D\u0435
        \u0441 \u043C\u043E\u0438\u043C \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u043C
        \u0434\u0435\u043B\u044C\u0446\u0435\u043C?"
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u0441\u043E\u0431\u0440\u0430\u0442\u044C
        \u0431\u043E\u043B\u044C\u0448\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
        \u043B\u0438\u0441\u0442\u044C\u0435\u0432, \u0447\u0442\u043E\u0431\u044B
        \u0443\u0441\u043F\u0435\u0442\u044C \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C
        \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E. \u041D\u043E \u0441\u0435\u0439\u0447\u0430\u0441
        \u044F \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0437\u0430\u043D\u044F\u0442\u044C
        \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u043E\u0439. "
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041C\u043E\u0436\u0435\u0448\u044C \u0434\u043E\u0431\u044B\u0442\u044C
        \u0438\u0445 \u0434\u043B\u044F \u043C\u0435\u043D\u044F? "
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u0410 \u0435\u0449\u0451, \u043F\u043E\u043A\u0430 \u043D\u0435
        \u0443\u0448\u043B\u0430, \u0432\u043E\u0437\u044C\u043C\u0438 \u044D\u0442\u043E\u0442
        \u0442\u043E\u043F\u043E\u0440. \u041E\u043D \u043F\u043E\u043C\u043E\u0436\u0435\u0442
        \u0442\u0435\u0431\u0435 \u043F\u043E\u0440\u0443\u0431\u0438\u0442\u044C
        \u0432\u043E-\u043E-\u043E\u043D \u0442\u0435 \u043A\u0443\u0441\u0442\u044B.  "
  InProgress:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u0422\u044B \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u043B\u0438\u0441\u0442\u044C\u044F?"
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041D\u0435\u0442? \u0422\u043E\u0433\u0434\u0430 \u043F\u043E\u0442\u043E\u0440\u043E\u043F\u0438\u0441\u044C.
        \u041C\u044B \u0441\u043A\u043E\u0440\u043E \u043E\u0442\u043A\u0440\u043E\u0435\u043C\u0441\u044F."
  CompleteQuest:
    Sentences:
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E. \u0422\u0435\u043F\u0435\u0440\u044C
        \u044F \u0441\u043C\u043E\u0433\u0443 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
        \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434 \u0443\u0441\u043A\u043E\u0440\u0438\u0442\u0435\u043B\u044F\u043C\u0438.  "
    - dialogueCharacter: {fileID: 11400000, guid: a19a80e9dce4f9603b1b63a43d7e72df, type: 2}
      sentence: "\u041A\u0441\u0442\u0430\u0442\u0438, \u0435\u0441\u043B\u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u0451\u0448\u044C
        \u043C\u043D\u0435 \u0435\u0449\u0451 \u043B\u0438\u0441\u0442\u044C\u0435\u0432,
        \u044F \u0441\u043C\u043E\u0433\u0443 \u043F\u043E\u043C\u043E\u0447\u044C
        \u0442\u0435\u0431\u0435 \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C
        \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
        \u0438 \u0440\u0443\u0431\u043A\u0438."
  NoQuests:
    Sentences: []
